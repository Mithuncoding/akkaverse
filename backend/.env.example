# ============================================================
# Akkaverse Backend — environment template
# Copy to `.env`. NEVER commit the real `.env`.
# ============================================================

# --- App ---
APP_NAME=Akkaverse API
ENVIRONMENT=development          # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# --- CORS (comma-separated origins allowed to call the API) ---
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Database ---
# For docker compose, host is the service name `db`; for local, use localhost.
DATABASE_URL=postgresql+psycopg://akkaverse:change_me@localhost:5432/akkaverse

# --- AI providers (filled in when chat/RAG is implemented) ---
GEMINI_API_KEY=
LLM_PROVIDER=gemini             # gemini | openai
LLM_MODEL=gemini-1.5-flash

# --- Auth (Clerk JWT verification) ---
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=
