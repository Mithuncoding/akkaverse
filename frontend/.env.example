# ─────────────────────────────────────────────────────────────────────────────
# Akkaverse — environment variables
# Copy this file to `.env.local` and fill in your values. `.env.local` is
# gitignored and is never committed.
# ─────────────────────────────────────────────────────────────────────────────

# NVIDIA NIM API key from NVIDIA Build (https://build.nvidia.com).
# SERVER-ONLY — no NEXT_PUBLIC prefix, so the key never reaches the browser.
# The app works fully without it (curated knowledge base + seeded answers);
# set it to enable richer, grounded, streamed AI answers from Akka.
NVIDIA_API_KEY=

# Optional model override. The default is high-quality; answers are also
# grounded live from Wikipedia (keyless) which keeps facts accurate.
# Recommended (best quality, use on Vercel): meta/llama-3.3-70b-instruct
# Fast + cheap (good for slow local networks): meta/llama-3.1-8b-instruct
# Kannada-first alt:                            sarvamai/sarvam-m
NIM_MODEL=meta/llama-3.3-70b-instruct

# Optional endpoint override (OpenAI-compatible NIM base URL).
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1
