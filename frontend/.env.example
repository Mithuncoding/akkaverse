# ─────────────────────────────────────────────────────────────────────────────
# Akkaverse — environment variables
# Copy this file to `.env.local` and fill in your values. `.env.local` is
# gitignored and is never committed.
# ─────────────────────────────────────────────────────────────────────────────

# Gemini API key from Google AI Studio (https://aistudio.google.com/apikey).
# SERVER-ONLY — no NEXT_PUBLIC prefix, so the key never reaches the browser.
# The app works fully without it (curated knowledge base fallback); set it to
# enable richer, grounded AI answers in the Kannada assistant.
GEMINI_API_KEY=

# Optional model override. Defaults to the cheapest capable model.
# gemini-2.5-flash-lite — $0.10 / $0.40 per 1M tokens, generous free tier.
GEMINI_MODEL=gemini-2.5-flash-lite
